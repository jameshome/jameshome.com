---
import Layout from "../../layouts/NoteLayout.astro";
import Prose from "../../components/Prose.astro";
import IconBack from "../../assets/icons/icon-back.svg";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const notes = await getCollection("documents");
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<Layout>
  <article class="pb-24">
    <div class="mx-auto my-6 max-w-3xl px-4">
      <a
        href="/notes"
        class="text-red inline-flex items-center justify-center rounded-full bg-white p-2 hover:scale-110"
        ><IconBack /></a
      >
      <h1 class="font-script text-red mt-2 text-6xl">
        {note.data.title}
      </h1>
    </div>
    <Prose>
      <Content />
    </Prose>
  </article>
</Layout>
