---
import Layout from "../layouts/GlobalLayout.astro";
import { getEntry, render } from "astro:content";
import Timeline from "../components/Timeline.astro";
import Homestar from "../components/Homestar.astro";
import Homestars from "../components/Homestars.astro";
import Prose from "../components/Prose.astro";

const [introEntry, bioEntry, nowEntry] = await Promise.all([
  getEntry("documents", "intro"),
  getEntry("documents", "bio"),
  getEntry("documents", "now"),
]);
const [{ Content: Intro }, { Content: Bio }, { Content: Now }] =
  await Promise.all([render(introEntry!), render(bioEntry!), render(nowEntry!)]);
---

<Layout>
  <div class="relative mx-auto my-0 max-w-5xl">
    <img
      src="/logo-jameshome.svg"
      alt="JAMES HOME"
      class="absolute top-0 right-0 m-4 w-1/4"
    />
    <img
      src="/properbusiness.svg"
      alt="Value judgments are destructive to our proper business, which is curiosity and awareness. — John Cage"
      class="mx-auto max-h-screen w-3/4 py-4"
    />
  </div>
  <Homestars />
  <Prose>
    <Intro />
  </Prose>
  <Homestars />
  <Prose>
    <Bio />
  </Prose>
  <Prose>
    <Now />
    As ever <span style="color: rgba(226, 0, 0, 1);">—</span>
  </Prose>

  <img class="mx-auto" alt="- J." src="/chop.svg" />

  <div
    class="text-grey mx-auto max-w-3xl px-4 text-right font-sans text-base uppercase"
  >
    Port Townsend, Cascadia, July 02025
  </div>

  <div
    class="font-script text-red mx-auto my-40 max-w-3xl -rotate-20 text-center text-6xl"
  >
    <a href="https://signal.me/#p/4152445464">+1 415 244 5464</a>
    <Homestar class="mx-auto my-10 rotate-20" />
    <a href="mailto:jh@jameshome.com">jh@jameshome.com</a>
  </div>
  <Homestars />
  <Timeline />
  <Homestars />
  <figure class="relative w-full bg-black">
    <img
      src="/jameshome-02025.jpg"
      alt="James Home shot by Christopher Michel"
      class="mx-auto w-3/4 md:w-1/2"
    />
    <figcaption
      class="absolute right-5 bottom-5 origin-bottom-right rotate-90 font-sans text-sm text-white/50 uppercase"
    >
      Photo by <a href="https://www.christophermichel.com/"
        >Christopher Michel</a
      >
    </figcaption>
  </figure>
  <a href="/"
    ><img src="/logo-jameshome.svg" alt="HOME" class="mx-auto my-20 w-40" /></a
  >
</Layout>
